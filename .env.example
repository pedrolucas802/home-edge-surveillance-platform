CAMERA_ID=cam1
CAMERA_HOSTS=cam1=192.168.0.90,cam2=192.168.0.89
CAM_HOST=192.168.0.90
CAM_PORT=554
CAM_USER=admin
CAM_PASS=YOUR_CAMERA_PASSWORD
CAM_STREAM=onvif2

# Optional full override. If set, this is used instead of CAM_* assembly.
# RTSP_URL=rtsp://admin:YOUR_CAMERA_PASSWORD@192.168.0.90:554/onvif2

RTSP_TRANSPORT=udp
FFMPEG_BIN=/opt/homebrew/bin/ffmpeg
FFMPEG_LOGLEVEL=error
FRAME_WIDTH=640
FRAME_HEIGHT=360
FRAME_FPS=15
SOURCE_FPS=15
USE_HWACCEL=true
RECONNECT_DELAY_SECONDS=1.0
READ_TIMEOUT_SECONDS=2.0
STARTUP_TIMEOUT_SECONDS=8.0
STARTUP_ATTEMPTS=3
WINDOW_NAME="Home Edge Surveillance Preview"
WINDOW_SCALE=2.5
DASHBOARD_ENABLED=true
DASHBOARD_DIR=data/dashboard
DASHBOARD_PUBLISH_INTERVAL_SECONDS=1.0
DASHBOARD_EVENT_COOLDOWN_SECONDS=3.0
CAMERA_PUBLISHERS_ENABLED=true

YOLO_ENABLED=true
YOLO_MODEL=models/home-surveillance-yolo26m-best.pt
YOLO_DEVICE=mps
YOLO_CONFIDENCE=0.20
YOLO_IOU=0.45
YOLO_IMGSZ=960
YOLO_CLASSES=person,cat,dog,car,car_plate
YOLO_INFER_EVERY_N=2
YOLO_TRACKING=true
YOLO_TRACKER=bytetrack.yaml
YOLO_TRACK_HISTORY=30
